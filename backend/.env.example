# Environment Variables required for Backend

# 1. Server Port (Render.com will provide this automatically, but for local it is usually 5000)
PORT=5000

# 2. Secret key for signing JWT tokens. Use a random, strong string for production.
JWT_SECRET=super_secret_key_here

# 3. PostgreSQL Database Connection URL.
# If you are using neon.tech or supabase, it will look something like this:
# postgresql://username:password@hostname/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/flowtask?schema=public"
